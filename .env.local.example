# Supabase 配置
# 在 Supabase Dashboard → Settings → API 页面获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# 服务角色密钥（仅在服务器端使用，切勿暴露在客户端），拥有很高的权限，请妥善保管
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 网站标题（显示在导航栏和页面标题）
NEXT_PUBLIC_SITE_TITLE=字里行间

# 网站URL，涉及重置密码回调等功能，部署生产环境需要正确填写成域名
NEXT_PUBLIC_SITE_URL=https://your-domain.com

NEXT_PUBLIC_SITE_DESCRIPTION=不止是博客，更是交流的空间

# LLM API 密钥，OpenAI 兼容，用于 AI 生成摘要
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

# 超级管理员邮箱列表（多个用逗号分隔），拥有删除用户等管理权限
SUPER_ADMIN_EMAILS=admin@example.com

# gitea webhook自动部署代码的密钥
WEBHOOK_SECRET="12ae5ead*************"
