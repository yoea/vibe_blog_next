# template

# 开发环境或者DEBUG=true 时将会打开日志输出，生产环境请务必设置 DEBUG=false 并把NODE_ENV=production来关闭日志输出以提升性能和安全性。
DEBUG=true

NODE_ENV=development

# Supabase 配置
# 在 Supabase Dashboard → Settings → API 页面获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# 服务角色密钥（仅在服务器端使用，切勿暴露在客户端），拥有很高的权限，请妥善保管
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# gitea webhook自动部署代码的密钥
WEBHOOK_SECRET="12ae5ead*************"

# 以下为用户自定义信息
# 网站标题（显示在导航栏和页面标题）
NEXT_PUBLIC_SITE_TITLE=字里行间

# 网站URL，涉及重置密码回调等功能，部署生产环境需要正确填写成域名
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# 网站副标题
NEXT_PUBLIC_SITE_DESCRIPTION=不止是博客，更是交流的空间

# 大模型API 密钥，OpenAI 兼容，用于 AI 生成摘要
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

# ====================
# 本地部署配置（npm run deploy:local 使用）
# SSH 连接信息建议配置在 ~/.ssh/config 中，脚本通过 Host 别名连接
# 以下变量可选，用于覆盖默认值
# ====================
# SSH_HOST=ewing.top                    # SSH Host 别名（默认 ewing.top，对应 ~/.ssh/config 中的 Host）
# SERVER_DIR=/home/ewing/craft/vibe_blog_next  # 服务器项目目录（默认 /home/ewing/craft/vibe_blog_next）