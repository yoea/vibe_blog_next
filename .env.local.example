# template

# 开发环境时将会打开日志输出，生产环境请务必设置 NODE_ENV=production 关闭日志输出以提升性能和安全性。
NODE_ENV=production

# Supabase 配置
# 在 Supabase Dashboard → Settings → API 页面获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# 服务角色密钥（仅在服务器端使用，切勿暴露在客户端），拥有很高的权限，请妥善保管
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# gitea webhook自动部署代码的密钥
WEBHOOK_SECRET="12ae5ead*************"

# 以下为用户自定义信息
# 网站标题（显示在导航栏和页面标题）
NEXT_PUBLIC_SITE_TITLE=字里行间

# 网站副标题（在个人中心编辑，管理员设置后自动在首页标题下方显示）

# ====================
# 本地部署配置（npm run deploy:local 使用）
# SSH 连接信息建议配置在 ~/.ssh/config 中，脚本通过 Host 别名连接
# 以下变量可选，用于覆盖默认值
# ====================
# SSH_HOST=ewing.top                    # SSH Host 别名（默认 ewing.top，对应 ~/.ssh/config 中的 Host）
# SERVER_DIR=/home/ewing/craft/vibe_blog_next  # 服务器项目目录（默认 /home/ewing/craft/vibe_blog_next）